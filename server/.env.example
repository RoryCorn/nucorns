PORT=4000
CLIENT_ORIGIN=http://localhost:5173
SESSION_SECRET=change-me-in-production

# Required for real AI moderation (hate/harassment/explicit text classification).
# Without it, moderation falls back to a local regex check and marks content "unverified".
ANTHROPIC_API_KEY=

# Email notifications for ad inquiries — sent to rcorn88@gmail.com on each submission.
# Create a Gmail App Password at: myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the Gmail account first)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Production only ----------------------------------------------------------
# Set to "production" to serve the built client (client/dist) and enable
# secure session cookies. Leave unset for local dev (Vite serves the client).
NODE_ENV=

# Absolute paths to a persistent disk, so the database and uploaded media
# survive deploys/restarts. Leave unset to use the default local folders.
DATA_DIR=
UPLOAD_DIR=
